rules_version = '2';
// ============================================================================
// FIRESTORE SECURITY RULES — Unified (My Volley Scout + My Volley Team Analysis)
// Progetto Firebase condiviso: volley-data-studio
//
// Strutture dati:
//   [MVS]  users/{email}/teams/{teamId}/...
//   [MVS]  users/{email}/invites/{inviteId}
//   [MVS]  users/{email}/shared_teams/{mirrorId}   ← cache UI (non fonte di verità)
//   [MVTA] volley_team_analysis_6_0/{uid}/datasets/{docId}
//   [MVTA] volley_team_analysis_6_0_users/{uid}
//   [MVTA] volley_team_analysis_6_0_shared_access/{ownerUid}
//   [MVTA] volley_team_analysis_6_0_share_tokens/{token}
//   [MVTA] volley_team_analysis_6_0_profile_requests/{uid}
//   [MVTA] volley_team_analysis_6_0_user_usage/{uid}
//   [MVTA] volley_team_analysis_6_0_news/{ownerUid}
//   [MVTA] volley_team_analysis_6_0_offers/{ownerUid}
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funzioni helper comuni ─────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // MVTA: identità basata su Firebase Auth UID
    function isOwner(ownerUid) {
      return isSignedIn() && request.auth.uid == ownerUid;
    }

    // MVS: identità basata su email
    // (i documenti MVS sono indicizzati per email, non per UID)
    function isUser(userId) {
      return isSignedIn() && (
        request.auth.uid    == userId ||
        request.auth.token.email == userId ||
        request.auth.token.email.replace('.', '_') == userId
      );
    }

    function isBootstrapAdminEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == 'peraimodel@gmail.com';
    }

    function requesterEmail() {
      return request.auth.token.email != null ? request.auth.token.email.lower() : '';
    }

    function isAdminUser() {
      let userRef = /databases/$(database)/documents/volley_team_analysis_6_0_users/$(request.auth.uid);
      let mvsRef = /databases/$(database)/documents/users/$(requesterEmail());
      let mvsSafeRef = /databases/$(database)/documents/users/$(requesterEmail().replace('.', '_'));
      return isSignedIn()
        && (isBootstrapAdminEmail()
            || (exists(userRef) && get(userRef).data.role == 'admin')
            || (requesterEmail() != '' && exists(mvsRef) && (
                  get(mvsRef).data.role == 'admin'
                  || get(mvsRef).data.apps.mvs.role == 'admin'
               ))
            || (requesterEmail() != '' && exists(mvsSafeRef) && (
                  get(mvsSafeRef).data.role == 'admin'
                  || get(mvsSafeRef).data.apps.mvs.role == 'admin'
               )));
    }

    function isOwnUserDoc(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Funzioni di condivisione MVTA ──────────────────────────────────────

    function isShareEnabled(data) {
      return !('enabled' in data) || data.enabled == true;
    }

    function hasPublicAccess(data) {
      return (('publicAccess' in data) && data.publicAccess == true)
        || (!('publicAccess' in data) && (!('allowedEmails' in data) || data.allowedEmails.size() == 0));
    }

    function hasRestrictedAccess(data) {
      return ('allowedEmails' in data)
        && request.auth.token.email != null
        && request.auth.token.email.lower() in data.allowedEmails;
    }

    function hasWriterAccess(data) {
      return ('writerEmails' in data)
        && request.auth.token.email != null
        && request.auth.token.email.lower() in data.writerEmails;
    }

    function isAllowedReader(ownerUid) {
      let sharedRef = /databases/$(database)/documents/volley_team_analysis_6_0_shared_access/$(ownerUid);
      let d = get(sharedRef).data;
      return isSignedIn()
        && exists(sharedRef)
        && isShareEnabled(d)
        && (hasPublicAccess(d) || hasRestrictedAccess(d));
    }

    function isAllowedWriter(ownerUid) {
      let sharedRef = /databases/$(database)/documents/volley_team_analysis_6_0_shared_access/$(ownerUid);
      let d = get(sharedRef).data;
      return isSignedIn()
        && exists(sharedRef)
        && isShareEnabled(d)
        && hasWriterAccess(d);
    }

    // ── Funzioni di accesso MVS (team sharing) ─────────────────────────────

    // Verifica che esista un documento user_access ATTIVO per il richiedente.
    // Usa get() per controllare il campo active: false blocca sia gli utenti sospesi
    // che quelli rimossi (il documento viene eliminato da removeTeamObserverAccess,
    // quindi exists() restituirà false).
    function hasTeamAccess(ownerId, teamId) {
      let ref1 = /databases/$(database)/documents/users/$(ownerId)/teams/$(teamId)/user_access/$(request.auth.token.email);
      let ref2 = /databases/$(database)/documents/users/$(ownerId)/teams/$(teamId)/user_access/$(request.auth.token.email.replace('.', '_'));
      return isSignedIn() && (
        (exists(ref1) && get(ref1).data.get('active', true) != false) ||
        (exists(ref2) && get(ref2).data.get('active', true) != false)
      );
    }

    // ══════════════════════════════════════════════════════════════════════
    // REGOLE MY VOLLEY SCOUT (MVS)
    // ══════════════════════════════════════════════════════════════════════

    // Documento radice utente MVS
    match /users/{userId} {
      allow read, write: if isUser(userId) || isAdminUser();
    }

    // Wildcard per tutte le subcollection MVS: solo il proprietario
    // (le regole più specifiche sotto sovrascrivono per i team condivisi)
    match /users/{userId}/{document=**} {
      allow read, write: if isUser(userId) || isAdminUser();
    }

    // Team: lettura anche agli observer con accesso attivo
    // NOTA DI SICUREZZA: la condizione è SOLO hasTeamAccess (controlla user_access).
    // Il mirror shared_teams è cache UI e NON è mai usato come condizione di accesso.
    match /users/{ownerId}/teams/{teamId} {
      allow read:  if isUser(ownerId) || hasTeamAccess(ownerId, teamId);
      allow write: if isUser(ownerId);
    }

    match /users/{ownerId}/teams/{teamId}/{document=**} {
      allow read:  if isUser(ownerId) || hasTeamAccess(ownerId, teamId);
      allow write: if isUser(ownerId);
    }

    // Documento user_access: leggibile dall'owner, dall'observer stesso
    // e da chiunque abbia già accesso attivo (per logObserverTeamAccess)
    match /users/{ownerId}/teams/{teamId}/user_access/{userId} {
      allow read:          if isUser(ownerId) || isUser(userId) || hasTeamAccess(ownerId, teamId);
      allow create, update: if isUser(ownerId) || isUser(userId);
      allow delete:        if isUser(ownerId);
    }

    // Mirror lato observer (cache UI: users/{observerId}/shared_teams/{ownerId}__{teamId})
    // La wildcard sopra garantisce già read+write all'observer.
    // Questa regola aggiunge il permesso al proprietario del team di eliminare
    // o disattivare il mirror quando revoca l'accesso (mirrorId = {ownerEmail}__{teamId}).
    match /users/{observerId}/shared_teams/{mirrorId} {
      allow update, delete: if isSignedIn() && (
        isUser(observerId) ||
        mirrorId.matches(request.auth.token.email + '__.*') ||
        mirrorId.matches(request.auth.token.email.replace('.', '_') + '__.*')
      );
    }

    // Inviti condivisione team
    // Sicurezza: get (singolo documento) permesso a qualsiasi utente autenticato che ha l'ID esatto
    // del documento (= token segreto ricevuto via link). List (elenco completo) solo al proprietario.
    match /users/{ownerId}/invites/{inviteId} {
      allow get:   if isSignedIn();
      allow list:  if isUser(ownerId);
      allow write: if isUser(ownerId);
    }

    match /teamInvites/{inviteId} {
      allow read:          if isSignedIn();
      allow create:        if false;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.token.email;
    }

    // Regole legacy (collection flat MVS pre-migrazione)
    match /matches/{matchId} {
      allow read, write: if request.auth != null && (
        resource.data.userId         == request.auth.token.email ||
        resource.data.userId         == request.auth.token.email.replace('.', '_') ||
        resource.data.userId         == request.auth.uid ||
        request.resource.data.userId == request.auth.token.email ||
        request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
        request.resource.data.userId == request.auth.uid
      );
    }

    match /rosters/{rosterId} {
      allow read, write: if request.auth != null && (
        resource.data.userId         == request.auth.token.email ||
        resource.data.userId         == request.auth.token.email.replace('.', '_') ||
        resource.data.userId         == request.auth.uid ||
        request.resource.data.userId == request.auth.token.email ||
        request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
        request.resource.data.userId == request.auth.uid
      );
    }

    match /teams/{teamId} {
      allow read, write: if request.auth != null && (
        resource.data.userId         == request.auth.token.email ||
        resource.data.userId         == request.auth.token.email.replace('.', '_') ||
        resource.data.userId         == request.auth.uid ||
        request.resource.data.userId == request.auth.token.email ||
        request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
        request.resource.data.userId == request.auth.uid
      );
    }

    // ══════════════════════════════════════════════════════════════════════
    // REGOLE UNIFICATE MVTA (nuove sub-collection sotto users/)
    // ══════════════════════════════════════════════════════════════════════

    // Shared access config (users/{uid}/shared_access/config)
    match /users/{ownerUid}/shared_access/{docId} {
      allow read: if isUser(ownerUid)
        || (isSignedIn()
            && isShareEnabled(resource.data)
            && (hasPublicAccess(resource.data) || hasRestrictedAccess(resource.data)));
      allow create, update, delete: if isUser(ownerUid);
    }

    // News (users/{uid}/news/{docId})
    match /users/{ownerUid}/news/{docId} {
      allow read: if isUser(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete: if isUser(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Offers (users/{uid}/offers/{docId})
    match /users/{ownerUid}/offers/{docId} {
      allow read: if isUser(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete: if isUser(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Usage log (users/{uid}/usage/{docId})
    match /users/{ownerUid}/usage/{docId} {
      allow get: if isUser(ownerUid) || isAdminUser();
      allow list: if isAdminUser();
      allow create, update: if isUser(ownerUid);
      allow delete: if isAdminUser();
    }

    // Global share tokens (users/_global_tokens/share_tokens/{token})
    match /users/_global_tokens/share_tokens/{token} {
      allow read: if isSignedIn()
        && isShareEnabled(resource.data)
        && (resource.data.ownerUid == request.auth.uid
            || isAllowedReader(resource.data.ownerUid));
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Admin content (users/_admin/content/{docId})
    match /users/_admin/content/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdminUser();
    }

    // ══════════════════════════════════════════════════════════════════════
    // REGOLE MY VOLLEY TEAM ANALYSIS (MVTA) — LEGACY
    // ══════════════════════════════════════════════════════════════════════

    // Dataset match e calendario
    match /volley_team_analysis_6_0/{ownerUid}/datasets/{docId} {
      allow read:                    if isOwner(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete:  if isOwner(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Bacheca team news
    match /volley_team_analysis_6_0_news/{ownerUid} {
      allow read:                    if isOwner(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete:  if isOwner(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Offerte team
    match /volley_team_analysis_6_0_offers/{ownerUid} {
      allow read:                    if isOwner(ownerUid) || isAllowedReader(ownerUid);
      allow create, update, delete:  if isOwner(ownerUid) || isAllowedWriter(ownerUid);
    }

    // Telemetria utilizzo utente
    match /volley_team_analysis_6_0_user_usage/{uid} {
      allow get:            if isOwnUserDoc(uid) || isAdminUser();
      allow list:           if isAdminUser();
      allow create, update: if isOwnUserDoc(uid)
        && request.resource.data.uid   == request.auth.uid
        && request.resource.data.email == requesterEmail();
      allow delete:         if isAdminUser();
    }

    // Richieste upgrade profilo
    match /volley_team_analysis_6_0_profile_requests/{uid} {
      allow get:    if isOwnUserDoc(uid) || isAdminUser();
      allow list:   if isAdminUser();
      allow create: if isOwnUserDoc(uid)
        && request.resource.data.uid            == request.auth.uid
        && request.resource.data.email          == requesterEmail()
        && request.resource.data.currentProfile in ['base', 'pro', 'promax']
        && request.resource.data.targetProfile  in ['pro', 'promax']
        && request.resource.data.status         == 'pending';
      allow update: if isAdminUser()
        || (isOwnUserDoc(uid)
            && resource.data.status                  == 'pending'
            && request.resource.data.uid             == resource.data.uid
            && request.resource.data.email           == resource.data.email
            && request.resource.data.currentProfile  in ['base', 'pro', 'promax']
            && request.resource.data.targetProfile   in ['pro', 'promax']
            && request.resource.data.status          == 'pending');
      allow delete: if isAdminUser();
    }

    // Configurazione condivisione MVTA (shared_access)
    // Usa resource.data direttamente per evitare get() ricorsivo sullo stesso documento
    match /volley_team_analysis_6_0_shared_access/{ownerUid} {
      allow read: if isOwner(ownerUid)
        || (isSignedIn()
            && isShareEnabled(resource.data)
            && (hasPublicAccess(resource.data) || hasRestrictedAccess(resource.data)));
      allow create, update, delete: if isOwner(ownerUid);
    }

    // Token di condivisione MVTA
    match /volley_team_analysis_6_0_share_tokens/{token} {
      allow read: if isSignedIn()
        && isShareEnabled(resource.data)
        && (resource.data.ownerUid == request.auth.uid
            || isAllowedReader(resource.data.ownerUid));
      allow create:        if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    // Registro utenti MVTA
    match /volley_team_analysis_6_0_users/{uid} {
      allow get:    if isOwnUserDoc(uid) || isAdminUser();
      allow list:   if isAdminUser();
      allow create: if isOwnUserDoc(uid)
        && request.resource.data.uid             == request.auth.uid
        && request.resource.data.email           == requesterEmail()
        && request.resource.data.assignedProfile in ['base', 'pro', 'promax']
        && request.resource.data.role            == (isBootstrapAdminEmail() ? 'admin' : 'user');
      allow update: if isAdminUser()
        || (isOwnUserDoc(uid)
            && request.resource.data.uid             == resource.data.uid
            && request.resource.data.email           == resource.data.email
            && request.resource.data.role            == resource.data.role
            && request.resource.data.assignedProfile == resource.data.assignedProfile);
      allow delete: if isAdminUser();
    }

  }
}

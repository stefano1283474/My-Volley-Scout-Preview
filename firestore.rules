rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isUser(userId) {
      return isSignedIn() && (request.auth.uid == userId ||
        request.auth.token.email == userId ||
        request.auth.token.email.replace('.', '_') == userId);
    }
    function hasTeamAccess(ownerId, teamId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/teamAccess/$(ownerId + '__' + teamId + '__' + request.auth.token.email)) ||
        exists(/databases/$(database)/documents/teamAccess/$(ownerId + '__' + teamId + '__' + request.auth.token.email.replace('.', '_'))) ||
        exists(/databases/$(database)/documents/users/$(request.auth.token.email)/teamAccess/$(ownerId + '__' + teamId)) ||
        exists(/databases/$(database)/documents/users/$(request.auth.token.email.replace('.', '_'))/teamAccess/$(ownerId + '__' + teamId))
      );
    }
    // Regole per le collection email-based - ogni utente può accedere solo alla propria collection
    match /{email}/{document=**} {
      allow read, write: if isSignedIn() && 
                          (email == request.auth.token.email || 
                           email == request.auth.token.email.replace('.', '_'));
    }
    
    // Regole per la collection users - documento utente
    match /users/{userId} {
      allow read, write: if isUser(userId);
    }

    // Regole per tutte le sottocollezioni sotto il documento utente
    // Necessario per consentire scritture in percorsi come
    // users/{userId}/teams/{teamId}/matches/{matchId}/...
    match /users/{userId}/{document=**} {
      allow read, write: if isUser(userId);
    }

    match /users/{ownerId}/teams/{teamId} {
      allow read: if isUser(ownerId) || hasTeamAccess(ownerId, teamId);
      allow write: if isUser(ownerId);
    }

    match /users/{ownerId}/teams/{teamId}/{document=**} {
      allow read: if isUser(ownerId) || hasTeamAccess(ownerId, teamId);
      allow write: if isUser(ownerId);
    }

    match /teamInvites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.token.email;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.token.email;
    }

    match /teamAccess/{accessId} {
      allow read: if isSignedIn() && (
        resource.data.userEmail == request.auth.token.email ||
        resource.data.userEmail == request.auth.token.email.replace('.', '_') ||
        resource.data.ownerId == request.auth.token.email ||
        resource.data.ownerId == request.auth.token.email.replace('.', '_')
      );
      allow create: if isSignedIn() && (
        request.resource.data.userEmail == request.auth.token.email ||
        request.resource.data.userEmail == request.auth.token.email.replace('.', '_') ||
        request.resource.data.ownerId == request.auth.token.email ||
        request.resource.data.ownerId == request.auth.token.email.replace('.', '_')
      );
      allow update, delete: if isSignedIn() && (
        resource.data.ownerId == request.auth.token.email ||
        resource.data.ownerId == request.auth.token.email.replace('.', '_')
      );
    }
    
    // Regole per le partite - accesso per email o UID
    match /matches/{matchId} {
      allow read, write: if request.auth != null && 
                          (resource.data.userId == request.auth.token.email || 
                           resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           resource.data.userId == request.auth.uid ||
                           request.resource.data.userId == request.auth.token.email ||
                           request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           request.resource.data.userId == request.auth.uid);
    }
    
    // Regole per i roster - accesso per email o UID
    match /rosters/{rosterId} {
      allow read, write: if request.auth != null && 
                          (resource.data.userId == request.auth.token.email || 
                           resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           resource.data.userId == request.auth.uid ||
                           request.resource.data.userId == request.auth.token.email ||
                           request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           request.resource.data.userId == request.auth.uid);
    }
    
    // Regole per le azioni di gioco - accesso per email o UID
    match /match_actions/{actionId} {
      allow read, write: if request.auth != null && 
                          (resource.data.userId == request.auth.token.email || 
                           resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           resource.data.userId == request.auth.uid ||
                           request.resource.data.userId == request.auth.token.email ||
                           request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           request.resource.data.userId == request.auth.uid);
    }
    
    // Regole per le statistiche - accesso per email o UID
    match /match_stats/{statId} {
      allow read, write: if request.auth != null && 
                          (resource.data.userId == request.auth.token.email || 
                           resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           resource.data.userId == request.auth.uid ||
                           request.resource.data.userId == request.auth.token.email ||
                           request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           request.resource.data.userId == request.auth.uid);
    }
    
    // Regole per i backup - accesso per email o UID
    match /backups/{backupId} {
      allow read, write: if request.auth != null && 
                          (resource.data.userId == request.auth.token.email || 
                           resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           resource.data.userId == request.auth.uid ||
                           request.resource.data.userId == request.auth.token.email ||
                           request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           request.resource.data.userId == request.auth.uid);
    }
    
    // Regole per le squadre - accesso per email o UID
    match /teams/{teamId} {
      allow read, write: if request.auth != null && 
                          (resource.data.userId == request.auth.token.email || 
                           resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           resource.data.userId == request.auth.uid ||
                           request.resource.data.userId == request.auth.token.email ||
                           request.resource.data.userId == request.auth.token.email.replace('.', '_') ||
                           request.resource.data.userId == request.auth.uid);
    }
  }
}
